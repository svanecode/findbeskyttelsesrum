{
  "compilerOptions": {
    "allowJs": true,
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": []
  },
  "include": ["**/*.ts", "**/*.tsx", "deno.d.ts"],
  "exclude": ["node_modules"]
} 